    {
      "parameters": {
        "fromEmail": "={{ $env.SMTP_FROM_EMAIL }}",
        "toEmail": "={{ $env.NOTIFY_EMAIL }}",
        "subject": "=New Enquiry from {{ $json.body.name }} — Covenant Day",
        "emailFormat": "html",
        "html": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>New Enquiry — Covenant Day</title>\n</head>\n<body style=\"margin:0;padding:0;background-color:#0d0c0b;font-family:'Georgia',serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#0d0c0b;padding:40px 20px;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#111110;border:1px solid rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;max-width:600px;width:100%;\">\n\n          <!-- Header -->\n          <tr>\n            <td style=\"background-color:#0d0c0b;padding:40px 48px 32px;text-align:center;border-bottom:1px solid rgba(255,255,255,0.06);\">\n              <img src=\"https://covenant-day.fly.dev/logo.png\" alt=\"Covenant Day\" width=\"160\" style=\"display:block;margin:0 auto 20px;opacity:0.95;\" />\n              <img src=\"https://covenant-day.fly.dev/rings.png\" alt=\"\" width=\"36\" style=\"display:block;margin:0 auto 16px;opacity:0.5;\" />\n              <p style=\"margin:0;color:rgba(212,175,100,0.9);font-size:10px;letter-spacing:0.3em;text-transform:uppercase;font-family:Arial,sans-serif;\">New Enquiry</p>\n            </td>\n          </tr>\n\n          <!-- Body -->\n          <tr>\n            <td style=\"padding:40px 48px;\">\n              <h1 style=\"margin:0 0 8px;color:#ffffff;font-size:26px;font-weight:normal;letter-spacing:0.02em;\">{{ $json.body.name }}</h1>\n              <p style=\"margin:0 0 32px;color:rgba(212,175,100,0.7);font-size:12px;letter-spacing:0.15em;text-transform:uppercase;font-family:Arial,sans-serif;\">has reached out through the website</p>\n\n              <!-- Details -->\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td style=\"padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.06);\">\n                    <p style=\"margin:0 0 4px;color:rgba(255,255,255,0.4);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;font-family:Arial,sans-serif;\">Email</p>\n                    <p style=\"margin:0;color:#ffffff;font-size:15px;font-family:Arial,sans-serif;\"><a href=\"mailto:{{ $json.body.email }}\" style=\"color:#d4af64;text-decoration:none;\">{{ $json.body.email }}</a></p>\n                  </td>\n                </tr>\n                {{ $json.body.phone ? '<tr><td style=\"padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.06);\"><p style=\"margin:0 0 4px;color:rgba(255,255,255,0.4);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;font-family:Arial,sans-serif;\">Phone</p><p style=\"margin:0;color:#ffffff;font-size:15px;font-family:Arial,sans-serif;\">{{ $json.body.phone }}</p></td></tr>' : '' }}\n                <tr>\n                  <td style=\"padding:20px 0 0;\">\n                    <p style=\"margin:0 0 10px;color:rgba(255,255,255,0.4);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;font-family:Arial,sans-serif;\">Message</p>\n                    <p style=\"margin:0;color:rgba(255,255,255,0.85);font-size:15px;line-height:1.7;white-space:pre-wrap;font-family:Arial,sans-serif;\">{{ $json.body.message }}</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- CTA -->\n          <tr>\n            <td style=\"padding:0 48px 40px;\">\n              <table cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td style=\"background-color:#d4af64;border-radius:3px;\">\n                    <a href=\"mailto:{{ $json.body.email }}?subject=Re: Your Covenant Day Enquiry\" style=\"display:inline-block;padding:14px 28px;color:#0d0c0b;font-family:Arial,sans-serif;font-size:12px;font-weight:bold;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;\">Reply to {{ $json.body.name.split(' ')[0] }}</a>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"background-color:#0d0c0b;padding:24px 48px;border-top:1px solid rgba(255,255,255,0.06);text-align:center;\">\n              <p style=\"margin:0;color:rgba(255,255,255,0.25);font-size:11px;letter-spacing:0.05em;font-family:Arial,sans-serif;\">Covenant Day &nbsp;&middot;&nbsp; covenantday.co.za</p>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
        "options": {}
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
